# LiteLLM model id ("provider/model"). Examples:
#   anthropic/claude-sonnet-4-5
#   mistral/mistral-small-latest
#   openai/gpt-4.1
#   ollama/qwen2.5:32b
TRAIL_BUDDY_MODEL=anthropic/claude-sonnet-4-5

# Provider API keys — set whichever provider TRAIL_BUDDY_MODEL points at.
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
OPENAI_API_KEY=

# Gradio bind address (optional).
GRADIO_HOST=127.0.0.1

# Logs are written to logs/trail_buddy.log and logs/trail_buddy.error.log.
TRAIL_BUDDY_LOG_DIR=logs
TRAIL_BUDDY_LOG_LEVEL=INFO

# Local RAG store. Scrapers/refresh jobs can update this folder; the app reads it.
TRAIL_BUDDY_RAG_STORE_DIR=rag_store
TRAIL_BUDDY_RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
TRAIL_BUDDY_RAG_RETRIEVER_K=5

# Weather tool (Open-Meteo, no API key required).
TRAIL_BUDDY_WEATHER_FORECAST_DAYS=7
TRAIL_BUDDY_WEATHER_HISTORICAL_YEARS=3
TRAIL_BUDDY_WEATHER_HISTORICAL_WINDOW_DAYS=7
TRAIL_BUDDY_WEATHER_TIMEOUT_S=10

# Web search tool (Tavily). Free tier at https://tavily.com (1000 searches/month).
# If unset, the web_search tool is silently disabled and the agent runs without it.
TAVILY_API_KEY=
TRAIL_BUDDY_WEB_SEARCH_MAX_RESULTS=5
TRAIL_BUDDY_WEB_SEARCH_DEPTH=basic
TRAIL_BUDDY_WEB_SEARCH_INCLUDE_ANSWER=true
